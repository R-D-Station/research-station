; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GodotStation"
config/version="8.0"
run/main_scene="res://Scenes/game/ui/MainMenu.tscn"
config/custom_user_dir_name="GodotStation"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://Assets/Icons/Ico/UACMGS_64x64.ico"
config/windows_native_icon="res://Assets/Icons/Ico/UACMGS_64x64.ico"
run/main_scene.dedicated_server="res://Scenes/server/ServerMain.tscn"

[autoload]

NetworkManager="*res://Scripts/network/NetworkManager.cs"
DedicatedServer="*res://Scripts/server/DedicatedServer.cs"
ServerConfig="*res://Scripts/server/ServerConfig.cs"
ServerRegistrar="*res://Scripts/server/ServerRegistrar.cs"
PreferenceManager="*res://Scripts/game/managers/PreferenceManager.gd"
BatchManager="*res://Scripts/game/managers/BatchManager.cs"
ClothingManager="*res://Scripts/game/managers/ClothingManager.cs"
FrameUpdateManager="*res://Scripts/game/managers/FrameUpdateManager.cs"
GameManager="*res://Scripts/game/managers/GameManager.cs"
ItemPoolManager="*res://Scripts/game/managers/ItemPoolManager.cs"
JobManager="*res://Scripts/game/managers/JobManager.cs"
ProfilingManager="*res://Scripts/game/managers/ProfilingManager.cs"
AudioManager="*res://Scripts/game/managers/AudioManager.gd"
UiAnimationHelper="*res://Scripts/game/ui/UIAnimationHelper.gd"
Scheduler="*res://Scripts/game/utils/Scheduler.cs"
DiscordRpc="*res://Scripts/game/utils/DiscordRPC.cs"
ServerPrivileges="*res://Scripts/game/utils/ServerPrivileges.cs"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="viewport"
window/stretch/aspect="expand"
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="GodotStation"

[editor_plugins]

enabled=PackedStringArray()

[export]

customized=true
include_filter="*.png,*.jpg,*.jpeg,*.tga,*.svg,*.bmp,*.hdr,*.exr,*.webp,*.ogg,*.wav,*.mp3,*.s3m,*.xm,*.it,*.mod,*.json,*.tres,*.res,*.gd,*.cs,*.gdshader,*.gdshaderinc,*.gdextension,*.dll,*.so,*.dylib,*.ttf,*.otf,*.woff,*.woff2,*.ogv,*.mp4,*.webm"
exclude_filter="*.import,*.tmp,*.bak,*.cache"
export_filter="all_resources"
script_export_mode=2
script_encryption_key=""

[export_filter]

include_filter="*.png,*.jpg,*.jpeg,*.tga,*.svg,*.bmp,*.hdr,*.exr,*.webp,*.ogg,*.wav,*.mp3,*.s3m,*.xm,*.it,*.mod,*.json,*.tres,*.res,*.gd,*.cs,*.gdshader,*.gdshaderinc,*.gdextension,*.dll,*.so,*.dylib,*.ttf,*.otf,*.woff,*.woff2,*.ogv,*.mp4,*.webm"
exclude_filter="*.import,*.tmp,*.bak,*.cache"

[file_customization]

folder_colors={
"res://Addons/": "red",
"res://Assets/": "orange",
"res://Godot Doc/": "teal",
"res://Scenes/": "blue",
"res://Scripts/": "gray",
"res://Sound/": "purple"
}

[filesystem]

import/snap/snap_2d_vertices_to_pixel=false

[global_group]

grid_tilemap=""

