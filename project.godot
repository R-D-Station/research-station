[layer_names]

2d_render/message_queue/max_size_mb=32
2d_render/max_threads=-1
2d_render/positional_shadow/atlas_quadrant_3_subdiv=4
2d_render/positional_shadow/atlas_quadrant_2_subdiv=3
2d_render/positional_shadow/atlas_quadrant_1_subdiv=2
2d_render/positional_shadow/atlas_quadrant_0_subdiv=2

[network]

firewall_checked=true

[physics]

2d/run_on_separate_thread=true
2d/physics_engine="GodotPhysics2D"
common/physics_interpolation=true
2d/physics_engine.rapier_client="Rapier2D"
2d/physics_engine.dedicated_server="GodotPhysics2D"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
2d/shadow_atlas/size=8192
textures/default_filters/use_nearest_mipmap_filter=true
textures/decals/filter=4
textures/light_projectors/filter=4
limits/opengl/max_renderable_lights=150
limits/opengl/max_lights_per_object=300
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
lightmapping/bake_performance/region_size=2048
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
anti_aliasing/bake_performance/region_size=512
anti_aliasing/main_scene="uid://dwdx03uq5hwnt"
2d/directional_shadow/soft_shadow_filter_quality=3
2d/positional_shadow/soft_shadow_filter_quality=3
