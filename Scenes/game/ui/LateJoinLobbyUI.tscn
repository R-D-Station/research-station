[sub_resource type="Shader" id="cctv_scanline_shader"]
code = "shader_type canvas_item;

uniform float scanline_count : hint_range(100, 1000) = 400.0;
uniform float scanline_opacity : hint_range(0.0, 1.0) = 0.15;
uniform float flicker_speed : hint_range(0.0, 10.0) = 2.0;
uniform float flicker_amount : hint_range(0.0, 0.3) = 0.05;

void fragment() {
	vec4 color = texture(TEXTURE, UV);
	float scanline = sin(UV.y * scanline_count) * scanline_opacity;
	float flicker = sin(TIME * flicker_speed) * flicker_amount;
	color.rgb -= scanline;
	color.rgb += flicker;
	COLOR = color;
}"

[sub_resource type="ShaderMaterial" id="cctv_scanline_material"]
shader = SubResource("cctv_scanline_shader")
shader_parameter/scanline_count = 400.0
shader_parameter/scanline_opacity = 0.15
shader_parameter/flicker_speed = 2.0
shader_parameter/flicker_amount = 0.05

